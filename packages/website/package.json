{
  "name": "use-eye-dropper-demo",
  "version": "1.7.2",
  "homepage": "http://woofers.github.io/use-eye-dropper",
  "license": "MIT",
  "scripts": {
    "clean": "rimraf .next out build use-eye-dropper public/chroma.js",
    "dev": "NODE_ENV=development next dev",
    "build": "pnpm clean && cp node_modules/chroma-js/dist/chroma.min.cjs public/chroma.js && next build --webpack && mv build use-eye-dropper && mkdir build && mv use-eye-dropper build",
    "start": "pnpx serve@latest build",
    "lint": "eslint .",
    "test": "playwright test",
    "test:ci": "xvfb-run --auto-servernum -- pnpm test:install",
    "test:install": "pnpm exec playwright install && pnpm test:skip",
    "test:skip": "SKIP_BUILD=true pnpm test",
    "format": "prettier --write \"{tests,src,public}/**/*.{js,mjs}\""
  },
  "dependencies": {
    "@stitches/react": "^1.2.8",
    "chroma-js": "^3.2.0",
    "esbuild": "^0.28.1",
    "framer-motion": "^12.42.0",
    "hast-util-to-html": "^9.0.5",
    "lowlight": "^3.3.0",
    "mdx-bundler": "^10.1.1",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "use-eye-dropper": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "1.21.1",
    "@svgr/webpack": "^8.1.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "file-loader": "^6.2.0",
    "gh-pages": "^6.3.0",
    "prettier": "^3.9.1",
    "serve": "^14.2.6",
    "serve-handler": "^6.1.7"
  }
}
